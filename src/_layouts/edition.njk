---
layout: base.njk
---

<article class="edition">
    <header class="edition-header">
        <h1 class="edition-number">No. {{ number | padStart(3) }}</h1>
        {% if title %}<p class="edition-title">{{ title }}</p>{% endif %}
        <time class="edition-date" datetime="{{ date | isoDate }}">{{ date | dateFormat }}</time>
    </header>

    <div class="edition-body">
        {{ content | safe }}
    </div>
    {% set prevEdition = collections.edition | getPreviousCollectionItem(page) %}
    {% set nextEdition = collections.edition | getNextCollectionItem(page) %}
    {% if prevEdition or nextEdition %}
    <nav class="edition-nav">
        {% if prevEdition %}
        <a href="{{ prevEdition.url }}" class="edition-nav-link edition-nav-prev">
            <span class="edition-nav-label">Previous</span>
            <span class="edition-nav-number">No. {{ prevEdition.data.number | padStart(3) }}</span>
        </a>
        {% else %}
        <span></span>
        {% endif %}
        {% if nextEdition %}
        <a href="{{ nextEdition.url }}" class="edition-nav-link edition-nav-next">
            <span class="edition-nav-label">Next</span>
            <span class="edition-nav-number">No. {{ nextEdition.data.number | padStart(3) }}</span>
        </a>
        {% endif %}
    </nav>
    {% endif %}
</article>

<div class="subscribe">
    <h2 class="subscribe-heading">Get it in your inbox</h2>
    <form method="POST" action="/.netlify/functions/subscribe">
        <p class="hidden"><label>Don't fill this out: <input name="bot-field"></label></p>
        <div class="subscribe-form">
            <input type="email" name="email" placeholder="you@example.com" required aria-label="Email address">
            <button type="submit">Subscribe</button>
        </div>
        <p class="subscribe-note">Weekly. Unsubscribe anytime. See our <a href="/privacy/">privacy policy</a>.</p>
    </form>
</div>
